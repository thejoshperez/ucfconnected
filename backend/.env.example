# ─────────────────────────────────────────────────────────────────────────────
# KnightLife — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# On macOS/Homebrew use your system username with no password.
# On Linux/Docker use: postgresql+asyncpg://postgres:postgres@localhost:5432/knightlife
DATABASE_URL=postgresql+asyncpg://YOUR_USERNAME@localhost:5432/knightlife

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CLASSIFIER_MODEL=phi3
EXTRACTOR_MODEL=mistral

# ── Instagram (optional for authenticated scraping) ───────────────────────────
# Authenticated sessions scrape more reliably and avoid rate limits.
INSTAGRAM_USERNAME=your_ig_username
INSTAGRAM_PASSWORD=your_ig_password

# Comma-separated list of club Instagram usernames to monitor
CLUB_ACCOUNTS=ucfknights,ucf_sga,ucf_engineering,ucf_gamedev,ucf_acm

# Number of most-recent posts to fetch per account per scrape run
POST_LIMIT=20

# ── OCR ───────────────────────────────────────────────────────────────────────
# Path to tesseract binary. Leave as "tesseract" if it is on your PATH.
TESSERACT_CMD=tesseract
IMAGE_DOWNLOAD_DIR=/tmp/knightlife_images

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allowed CORS origins (your frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Minimum classifier confidence to forward a post to the extractor
MIN_CONFIDENCE=0.6
