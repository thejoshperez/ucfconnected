# ─────────────────────────────────────────────────────────────────────────────
# KnightLife — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local dev (macOS/Homebrew):
#   DATABASE_URL=postgresql+asyncpg://YOUR_USERNAME@localhost:5432/knightlife
# Local dev (Linux):
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knightlife
# Docker Compose (set automatically by docker-compose.yml — do NOT change):
#   DATABASE_URL=postgresql+asyncpg://knightlife:knightlife@db:5432/knightlife
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knightlife

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev:    redis://localhost:6379/0
# Docker Compose (set automatically): redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CLASSIFIER_MODEL=phi3
EXTRACTOR_MODEL=mistral

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.0-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=2.0
# ── Instagram (optional for authenticated scraping) ───────────────────────────
# Authenticated sessions scrape more reliably and avoid rate limits.
INSTAGRAM_USERNAME=your_ig_username
INSTAGRAM_PASSWORD=your_ig_password

# Comma-separated list of club Instagram usernames to monitor
CLUB_ACCOUNTS=ucfknights,ucf_sga,ucf_engineering,ucf_gamedev,ucf_acm

# Number of most-recent posts to fetch per account per scrape run
POST_LIMIT=20

# ── Apify (failover for Instagram when Instaloader is blocked) ───────────────
APIFY_API_TOKEN=your_apify_api_token_here

# ── OCR ───────────────────────────────────────────────────────────────────────
# Path to tesseract binary. Leave as "tesseract" if it is on your PATH.
TESSERACT_CMD=tesseract
IMAGE_DOWNLOAD_DIR=/tmp/knightlife_images

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allowed CORS origins (your frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Minimum classifier confidence to forward a post to the extractor
MIN_CONFIDENCE=0.6

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRE_HOURS=24

# ── Admin (demo override) ────────────────────────────────────────────────────
# Secret key required to inject featured events via POST /events/admin/inject
ADMIN_SECRET_KEY=change-me-to-a-real-secret
